<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.arx-ccn.fastr</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/fastr</string>
    </array>

    <key>EnvironmentVariables</key>
    <dict>
        <key>FASTR_ADDR</key>
        <string>127.0.0.1</string>
        <key>FASTR_PORT</key>
        <string>8080</string>
        <key>FASTR_DATA_DIR</key>
        <string>/usr/local/var/fastr/data</string>
    </dict>

    <key>UserName</key>
    <string>_fastr</string>

    <key>WorkingDirectory</key>
    <string>/usr/local/var/fastr</string>

    <key>StandardOutPath</key>
    <string>/usr/local/var/log/fastr.log</string>

    <key>StandardErrorPath</key>
    <string>/usr/local/var/log/fastr.log</string>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>
</dict>
</plist>
